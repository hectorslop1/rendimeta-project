# ============================================
# RENDIMETA MONOREPO - ENVIRONMENT VARIABLES
# ============================================

# ============================================
# MOBILE APP (Flutter)
# ============================================
# API URL - Apunta al backend (app web)
API_URL=http://localhost:3000/api

# WebRTC Configuration (si se usa)
WEBRTC_ENABLED=false

# ============================================
# WEB APP (Next.js)
# ============================================
# Copiar estas variables a rendimeta-web/.env.local

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/rendimeta"

# Next.js
NEXT_PUBLIC_API_URL="http://localhost:3000"

# Authentication
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Session
SESSION_SECRET="your-super-secret-session-key-change-this-in-production"

# ============================================
# PRODUCTION ONLY
# ============================================
# NODE_ENV=production
# DATABASE_URL="postgresql://user:password@production-host:5432/rendimeta"
# NEXT_PUBLIC_API_URL="https://your-domain.com"
